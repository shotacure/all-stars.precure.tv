  // 例: 'https://xxxxxxxxxx.execute-api.ap-northeast-1.amazonaws.com/prod'
  API_BASE_URL: '',

  // Google Analytics 4 測定ID（例: 'G-XXXXXXXXXX'）
  // 空文字の場合はGA4を読み込まない
  GA4_MEASUREMENT_ID: '',
};
