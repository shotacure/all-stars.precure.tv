 * このファイルをコピーして config.js を作成し、実際の値を設定してください。
 *   cp config.js.example config.js
 *
 * config.js は .gitignore に含まれているため、リポジトリには含まれません。
 */

window.ALLSTARS_CONFIG = {
  // バックエンドAPI のベースURL（末尾スラッシュなし）
