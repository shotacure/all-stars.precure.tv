# SAM CLI configuration file
# Copy to samconfig.toml and fill in your values:
#   cp samconfig.toml.example samconfig.toml

version = 0.1

[default.build.parameters]
use_container = false

[default.deploy.parameters]
stack_name = "allstars-backend"
region = "ap-northeast-1"
confirm_changeset = true
capabilities = "CAPABILITY_IAM"
resolve_s3 = true
parameter_overrides = "SiteBucketName=\"YOUR_S3_BUCKET_NAME\" SessionSecret=\"YOUR_SECRET_KEY_MIN_32_CHARS\" CorsOrigin=\"https://your-domain.example.com\""
